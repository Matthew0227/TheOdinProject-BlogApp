<div id="<%= dom_id blog %>" class="space-y-2">
  <div>
    <h2 class="text-xl font-semibold text-gray-900"><%= blog.title %></h2>
  </div>

  <div>
    <p class="text-sm text-gray-600">Posted by <span class="font-medium text-gray-900"><%= blog.user&.username || "Unknown user" %></span></p>
  </div>

  <div>
    <p class="whitespace-pre-line text-sm text-gray-700"><%= blog.body %></p>
  </div>
</div>
