<div class="mx-auto md:w-2/3 w-full">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>
</div>

<div class="mx-auto max-w-4xl space-y-8">
  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <%= render @blog %>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <% if @blog.owned_by?(Current.user) %>
        <%= link_to "Edit this blog", edit_blog_path(@blog), class: "rounded-md bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200" %>
        <%= button_to "Destroy this blog", @blog, method: :delete, class: "rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
      <% end %>
      <%= link_to "Back to blogs", blogs_path, class: "rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 ring-1 ring-gray-300 hover:bg-gray-50" %>
    </div>
  </div>
  <p>Posted on <%= @blog.created_at.strftime("%B %d, %Y") %></p>
  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h4 class="mb-4 text-lg font-semibold text-gray-900">Comments</h4>

    <% if @blog.comments.any? %>
      <div class="space-y-3">
        <% @blog.comments.each do |comment| %>
          <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
            <div class="mb-2 flex items-center justify-between gap-3">
              <strong class="text-sm font-semibold text-gray-900"><%= comment.author %></strong>
              <div class="flex items-center gap-2">
                <% if comment.owned_by?(Current.user) %>
                  <%= link_to "Edit", edit_blog_comment_path(@blog, comment), class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
                <% end %>
                <% if comment.owned_by?(Current.user) || @blog.owned_by?(Current.user) %>
                  <%= button_to "Delete", blog_comment_path(@blog, comment), method: :delete, data: { turbo_confirm: "Delete this comment?" }, class: "cursor-pointer text-sm font-medium text-red-600 hover:text-red-700" %>
                <% end %>
              </div>
            </div>
            <p class="text-sm text-gray-700"><%= comment.body %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No comments yet.</p>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold text-gray-900">Add a Comment</h2>

    <%= form_with(model: [@blog, @comment], class: "space-y-4") do |form| %>
      <div>
        <%= form.label :author, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= form.text_field :author, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div>
        <%= form.label :body, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= form.text_area :body, rows: 4, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div>
        <%= form.submit "Post Comment", class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
      </div>
    <% end %>
  </div>
</div>
