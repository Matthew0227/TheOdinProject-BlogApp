<p class="mb-4 text-sm font-medium text-green-600"><%= notice %></p>

<% content_for :title, "Blogs" %>

<div class="mx-auto max-w-4xl space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-gray-900">Blogs</h1>
    <%= link_to "New blog", new_blog_path, class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
  </div>

  <div id="blogs" class="space-y-4">
    <% @blogs.each do |blog| %>
      <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
        <%= render blog %>
        <p >Posted on <%= blog.created_at.strftime("%B %d, %Y") %></p>
        <div class="mt-4">
          <%= link_to "Show this blog", blog, class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

