<div id="<%= dom_id comment %>" class="w-full space-y-3 rounded-lg border border-gray-200 bg-gray-50 p-4">
  <div>
    <strong class="mb-1 block text-sm font-semibold text-gray-900">Posted by</strong>
    <p class="text-sm text-gray-700"><%= comment.user&.username || "Unknown user" %></p>
  </div>
  <div>
    <strong class="mb-1 block text-sm font-semibold text-gray-900">Body</strong>
    <p class="text-sm text-gray-700"><%= comment.body %></p>
  </div>
  <div>
    <strong class="mb-1 block text-sm font-semibold text-gray-900">Blog</strong>
    <p class="text-sm text-gray-700"><%= comment.blog_id %></p>
  </div>
</div>
