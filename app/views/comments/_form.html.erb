<%= form_with(model: [@blog, @comment], class: "space-y-4") do |form| %>
  <% if @comment.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <h2 class="mb-2 font-semibold"><%= pluralize(@comment.errors.count, "error") %> prevented this comment from saving:</h2>

      <ul class="list-disc space-y-1 pl-5">
        <% @comment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :author, class: "mb-1 block text-sm font-medium text-gray-700" %>
    <%= form.text_field :author, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
  </div>

  <div>
    <%= form.label :body, class: "mb-1 block text-sm font-medium text-gray-700" %>
    <%= form.text_area :body, rows: 4, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
  </div>

  <%= form.submit "Save comment", class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
<% end %>